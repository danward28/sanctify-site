DirectoryIndex index.html

RewriteEngine On

RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^sanctify\.faith$ [NC]
RewriteRule ^ https://sanctify.faith%{REQUEST_URI} [R=301,L]

RewriteRule ^index\.html$ / [R=301,L]

RewriteRule ^pricing-2/?$ /pricing [R=301,L]
RewriteRule ^terms-of-service(?:\.html)?/?$ /terms [R=301,L]
RewriteRule ^family-internet-safety-guide/?$ /first-phone-kit [R=301,L]
RewriteRule ^family-internet-safety-guide\.html$ /first-phone-kit [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

<IfModule mod_headers.c>
  Header set Cache-Control "private"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
